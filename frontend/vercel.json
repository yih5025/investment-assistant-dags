{
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist", 
    "installCommand": "npm install",
    "rewrites": [
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ],
    "env": {
      "VITE_API_URL": "http://your-server-ip:30888",
      "VITE_WS_URL": "ws://your-server-ip:30888"
    }
  }